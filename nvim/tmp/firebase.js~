async function getFirebase(baustelle, bauID) {
  var accessToken = await getAccessToken();
  var checkAuth = await expiryCheck(accessToken);
  if (checkAuth == false) {
    accessToken = await refreshToken();
  }
  console.log(accessToken);

  const myHeaders = new Headers();

  myHeaders.append("Content-Type", "application/json");
  myHeaders.append("Authorization", "Bearer " + accessToken);
  const fetchPromise = fetch(url + port + "/firebase/" + bauID, {
    method: "GET",
    headers: myHeaders,
  });
  fetchPromise
    .then((response) => {
      return response.json();
    })
    .then((PromiseStatus) => {
      var routeData = PromiseStatus;

      document.getElementById("repTitle").innerHTML =
        "Reportliste: " + " (" + baustelle + ")";
      tableRow(routeData);

      //addRow(routeData)
    });
}

async function bauGet() {
  var check = loginCheck("user");

  if (check === null) {
    console.log("0006 - No User logged in");
    window.location.href = "./login.html";
  }
  var accessToken = await getAccessToken();
  var checkAuth = await expiryCheck(accessToken);
  if (checkAuth == false) {
    accessToken = await refreshToken();
  }
  console.log(accessToken);

  const myHeaders = new Headers();

  myHeaders.append("Content-Type", "application/json");
  myHeaders.append("Authorization", "Bearer " + accessToken);
  const fetchPromise = fetch(
    url + port + "/baustelle/" + check + "/" + archiveFlag, {
      method: "GET",
      headers: myHeaders,
    }
  );
  fetchPromise
    .then((response) => {
      return response.json();
    })
    .then((PromiseStatus) => {
      var routeData = PromiseStatus;

      var tableData = [];
      for (var i = 0; i < routeData.baustelle.length; i++) {
        if (routeData.defaultF[i] != "true") {
          var workingObj = JSON.parse(
            '{ "baustelle": "' +
              routeData.baustelle[i] +
              '","bauID":"' +
              routeData.bauID[i] +
              '","archive":"' +
              routeData.archive[i] +
              '"}'
          );

          tableData.push(workingObj);
        }
      }

      tableBau(tableData);
      //addRow(routeData)
    });
}

