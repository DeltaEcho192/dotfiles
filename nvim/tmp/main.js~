//Function to send emails
function sendEmail(data, subjectLine) {
	let jsonData = require("./config.json");

	var hostI = jsonData.host;
	var portI = jsonData.port;
	var userI = jsonData.senderemail;
	var pwI = jsonData.senderpw;

	let transport = nodemailer.createTransport({
		host: hostI,
		port: portI,
		auth: {
			user: userI,
			pass: pwI,
		},
	});

	Object.keys(data).forEach(function (key) {
		const message = {
			from: "report@vanoli-ag.ch", // Sender address
			to: key, // List of recipients
			subject: subjectLine, // Subject line
			html: data[key], // Plain text body
		};
		transport.sendMail(message, function (err, info) {
			if (err) {
				console.log(err);
			} else {
				console.log("Send All okay email");
				//console.log(info);
			}
		});
	});
}

