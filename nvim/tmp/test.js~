const nodemailer = require("nodemailer");
const { dir } = require("console");

function sendEmail(data, email) {
	let jsonData = require("./config.json");
	console.log(jsonData);
	var hostI = jsonData.host;
	var portI = jsonData.port;
	var userI = jsonData.senderemail;
	var pwI = jsonData.senderpw;
	console.log(hostI, portI, userI, pwI);

	let transport = nodemailer.createTransport({
		host: hostI,
		port: portI,
		secure: false,
		IgnoreTLS: true,
		tls: {
			// do not fail on invalid certs
			rejectUnauthorized: false,
		},
		auth: {
			user: userI,
			pass: pwI,
		},
	});

	const message = {
		from: "report@vanoli-ag.ch", // Sender address
		to: email, // List of recipients
		subject: "Passwort Reset", // Subject line
		html: data, // Plain text body
	};
	transport.sendMail(message, function (err, info) {
		if (err) {
			console.log(err);
		} else {
			console.log(info);
		}
	});
}

