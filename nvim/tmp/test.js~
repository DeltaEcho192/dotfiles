	async function getSingleDoc(docId) {
		if (fireSwitch == false) {
			var result = await db.collection("issues").findOne({_id: ObjectId(docId)});
			if (result == null) {
				console.log("No such document exists");
			} else {
				result = decodeMongo(result);
				return result;
			}
		} else {
			const issueRef = dbf.collection("issues").doc(docId);
			const doc = await issueRef.get();
			if (!doc.exists) {
				console.log("No such document!");
			} else {
				console.log("Document Was found");
			}
			return doc.data();
		}
	}

