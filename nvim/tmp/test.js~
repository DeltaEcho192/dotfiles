	//Checks if user has appropriate code status
async function checkCode(username) {
	var AuthQuery = { userID: username };
	var test = false;
	var code = false;
	var check = [];
	return new Promise((resolve, reject) => {
		db.collection("users")
			.find(AuthQuery)
			.toArray(async function (err, result) {
				if (err) throw err;

				if (Object.keys(result).length > 0) {
					if (result[0].code == 1) {
						test = true;
						code = true;
						check.push(test);
						check.push(code);
						resolve(check);
					}
					if (result[0].code == 2) {
						test = true;
						check.push(test);
						check.push(code);
						resolve(check);
					} else {
						resolve(false);
					}
				}
			});
	});
}

